# ============================================
# BOT SERVICE CONFIGURATION
# ============================================
# Server port
PORT=4444

# ============================================
# AUTHENTICATION
# ============================================
# API Key for authenticating requests from Convex
# Must match BOT_SERVICE_API_KEY in Convex env vars
# Generate: openssl rand -hex 32
BOT_SERVICE_API_KEY=your-secret-api-key-here

# ============================================
# CONVEX CONNECTION
# ============================================
# Convex deployment URL
CONVEX_URL=https://your-deployment.convex.cloud

# ============================================
# AI SUMMARY (Claude)
# ============================================
# Anthropic API Key (for meeting summaries)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ============================================
# TRANSCRIPTION PROVIDERS (3-Tier Fallback)
# ============================================
# At least one provider required. System uses 3-tier fallback:
# Tier 1: Recurring monthly free tiers (~24 hrs/month)
# Tier 2: One-time credits (~885 hrs total)
# Tier 3: Paid fallback (Deepgram at $0.0077/min)

# --- Tier 1: Recurring monthly free tiers ---

# Speechmatics - https://www.speechmatics.com/ (8 hrs/month)
SPEECHMATICS_API_KEY=your-speechmatics-key

# Gladia - https://www.gladia.io/ (10 hrs/month)
GLADIA_API_KEY=your-gladia-key

# Azure Speech - https://azure.microsoft.com/en-us/services/cognitive-services/speech-services/ (5 hrs/month)
AZURE_SPEECH_KEY=your-azure-key
AZURE_SPEECH_REGION=eastus

# Google Speech-to-Text - https://cloud.google.com/speech-to-text (1 hr/month)
# NOTE: This is different from Google OAuth (used in root .env)
# This is GCP Cloud API for transcription, not OAuth for sign-in
#
# Option 1: API Key (simpler)
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key
# Option 2: Project ID with default credentials (ADC)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# --- Tier 2: One-time credits ---

# Deepgram - https://deepgram.com/ (~700 hrs from $200 one-time credit)
# TODO: Sign up and get API key
DEEPGRAM_API_KEY=

# AssemblyAI - https://www.assemblyai.com/ (185 hrs one-time credit)
# TODO: Sign up and get API key
ASSEMBLYAI_API_KEY=

