{
  "name": "nixelo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10.28.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ],
    "*.json": [
      "biome format --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ]
  },
  "scripts": {
    "dev": "run-p dev:frontend dev:backend",
    "dev:cloud": "run-p dev:frontend dev:backend:cloud",
    "dev:frontend": "vite",
    "dev:backend": "convex dev",
    "dev:backend:setup-local": "convex dev --local --once",
    "dev:backend:cloud": "convex dev --env-file .env.local.cloud",
    "build": "convex codegen --typecheck disable && vite build",
    "biome": "biome check --write .",
    "biome:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc -b . --noEmit",
    "convex:generated:check": "node scripts/check-convex-generated.js",
    "static:codegen": "pnpm run convex:generated:check",
    "static:biome": "pnpm run biome:check",
    "static:typecheck": "pnpm run typecheck",
    "static:validate": "pnpm run validate",
    "static:screenshots": "pnpm run screenshots:integrity",
    "static": "run-s static:codegen static:biome static:typecheck static:validate static:screenshots",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:convex": "vitest --config vitest.convex.config.ts",
    "test:convex:ui": "vitest --config vitest.convex.config.ts --ui",
    "test:convex:coverage": "vitest --config vitest.convex.config.ts --coverage",
    "test:all": "run-s test:run test:convex:run",
    "test:run": "vitest run",
    "test:convex:run": "vitest --config vitest.convex.config.ts run",
    "validate": "node scripts/validate.js",
    "generate:routes": "tsr generate",
    "fixme": "run-s biome typecheck",
    "e2e": "playwright test",
    "e2e:preview": "playwright test -c playwright.preview.config.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:cross-browser:smoke": "E2E_CROSS_BROWSER=1 playwright test e2e/landing.spec.ts --workers=1 --reporter=line",
    "screenshots": "tsx --env-file=.env.local e2e/screenshot-pages.ts",
    "screenshots:integrity": "node scripts/screenshot-diff.js",
    "screenshots:check": "node scripts/screenshot-diff.js",
    "screenshots:diff": "node scripts/screenshot-diff.js",
    "screenshots:approve": "node scripts/screenshot-diff.js --approve",
    "kill-port": "node scripts/kill-port.cjs 5555",
    "build:e2e": "vite build --mode e2e",
    "preview": "vite preview",
    "preview:e2e": "vite preview --mode e2e",
    "prepare": "husky",
    "dev:purge": "convex run purge:purgeData \"{\\\"confirm\\\": true}\"",
    "mirror": "node scripts/scrape_full_mirror.js",
    "mirror:batch": "node scripts/mirror_batch.js",
    "inventory": "node scripts/check_inventory.js",
    "discover": "node scripts/discover_targets.js",
    "crawl": "node scripts/crawl_routes.js",
    "crawl:batch": "node scripts/crawl_batch.js",
    "select:targets": "node scripts/select_targets.js",
    "analyze": "node scripts/analyze_design.js",
    "setup:auth": "node scripts/setup_auth.js",
    "auth:manual": "node scripts/manual_handshake.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
